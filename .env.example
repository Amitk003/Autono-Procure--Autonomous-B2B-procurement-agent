# Anakin API credentials
ANAKIN_API_KEY=ak-your-key-here

# Wire API identity credential ID (from Anakin dashboard)
WIRE_CREDENTIAL_ID=cred-your-credential-id

# Gemini API key for AI-powered structured JSON extraction via Anakin
GEMINI_API_KEY=your-gemini-api-key

# Supplier configuration
PRIMARY_SUPPLIER_SKU=LAB-GRADE-ACETONE-99.9
PRIMARY_SUPPLIER_URL=https://example-b2b-supplier.com/product/LAB-ACETONE-99
PRIMARY_SUPPLIER_NAME=Acetone 99.9% Laboratory Grade
PRIMARY_SUPPLIER_VENDOR=Primary Lab Supply Co.
SUPPLIER_MIN_ORDER_QTY=1
SUPPLIER_UNIT_PRICE=45
SUPPLIER_CURRENCY=USD
POLL_INTERVAL_MS=30000

# Search configuration
SEARCH_LIMIT=5
SEARCH_MAX_URLS=10

# Agent configuration
AGENT_ID=autono-procure-v1
AGENT_DEFAULT_CONFIDENCE=0.85
AGENT_DELIVERY_DAYS_MIN=5
AGENT_DELIVERY_DAYS_MAX=15

# Logging
LOG_LEVEL=info
